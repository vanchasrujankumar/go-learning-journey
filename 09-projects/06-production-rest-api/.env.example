# Production-Grade REST API - Environment Template

# Server Configuration
PORT=8080
ENV=production

# MongoDB Configuration
MONGO_URI=mongodb://mongo:27017
MONGO_DB=go_api_db
MONGO_TIMEOUT=10s

# Kafka Configuration
KAFKA_BROKERS=kafka:9092
KAFKA_USER_TOPIC=user-events
KAFKA_PRODUCT_TOPIC=product-events
KAFKA_GROUP_ID=go-api-consumer-group

# JWT Configuration
JWT_SECRET=your-very-secret-key-change-in-production-immediately
JWT_EXPIRY=24h

# Server Timeouts
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s

# Logging
LOG_LEVEL=info

# Database
MAX_OPEN_CONNS=25
MAX_IDLE_CONNS=5
CONN_MAX_LIFETIME=5m
